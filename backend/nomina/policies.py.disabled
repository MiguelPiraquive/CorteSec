    action_map = {
        'list': 'ver',
        'retrieve': 'ver',
        'create': 'crear',
        'update': 'editar',
        'partial_update': 'editar',
        'destroy': 'eliminar',
        'aprobar_pago': 'aprobar_pago',
        'exportar_pagos': 'exportar',
    }
    
    statements = [
        {
            "action": ["list", "retrieve"],
            "principal": ["authenticated"],
            "effect": "allow",
        },
        {
            "action": ["create", "update", "partial_update"],
            "principal": ["authenticated"],
            "effect": "allow",
        },
        {
            "action": ["destroy", "aprobar_pago", "exportar_pagos"],
            "principal": ["authenticated"],
            "effect": "allow",
        },
    ]
